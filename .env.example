# EmailJS Configuration
# Get these from https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id_here
VITE_EMAILJS_NEWSLETTER_TEMPLATE_ID=your_newsletter_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Google Analytics
# Get this from https://analytics.google.com/
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudinary Configuration (for resume uploads in job applications)
# Sign up at https://cloudinary.com/ (free tier: 25GB storage)
# 1. Create account and get your cloud name from the dashboard
# 2. Go to Settings > Upload > Add upload preset (create an "unsigned" preset)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
